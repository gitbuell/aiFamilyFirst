# aiFamilyFirst Phase 2 backend — gated PHI service. Copy to .env; NEVER commit .env.
# This service stays OFF the public demo (aifamilyfirst.aibuell.com) until the
# HIPAA-GAP.md Phase 2 entry checklist is fully cleared.

# ---- Service ----
PORT=4003
# Bind to loopback only; the public internet must never reach this directly.
# Production access is via an authenticated, gated Caddy route (separate from the demo).
BIND_HOST=127.0.0.1

# ---- HARD COMPLIANCE GATE ----
# Real PHI endpoints refuse to run unless this is exactly "true".
# DO NOT set true until HIPAA-GAP.md checklist is cleared + Privacy Officer sign-off + BAAs signed.
PHI_ENABLED=false

# ---- Dedicated, ISOLATED PHI database (NOT the shared enterprise-postgres) ----
PGHOST=aifamilyfirst-phi-db
PGPORT=5432
PGUSER=aff_phi
PGPASSWORD=change_me_strong_password
PGDATABASE=aff_phi
# Require TLS to the DB in production (DO managed PG / configured server cert).
PGSSL=false

# ---- Field-level PHI encryption (AES-256-GCM). 32 bytes, base64. Generate: npm run genkey ----
# Store the real key in a secrets manager (Bitwarden/DO secrets), NOT in git.
MASTER_ENCRYPTION_KEY=

# ---- Session policy (HIPAA §164.312(a)(2)(iii) automatic logoff) ----
SESSION_IDLE_TIMEOUT_MIN=15
SESSION_ABSOLUTE_TIMEOUT_HOURS=12

# ---- Gemini / ICM (Phase 2 pipeline; requires signed Google BAA before real PHI) ----
GEMINI_API_KEY=

# ---- CORS: the authenticated PHI frontend origin (NOT the public demo) ----
CORS_ORIGIN=
